# --- Required ---
# Your bot token from the Discord Developer Portal (Bot -> Reset Token)
DISCORD_TOKEN=your-bot-token-here
# Your application's client id (General Information -> Application ID)
DISCORD_CLIENT_ID=your-application-id-here
# The id of the server this bot runs in. Slash commands are registered here.
DISCORD_GUILD_ID=your-guild-id-here

# --- Optional ---
# Where the SQLite database file lives.
DATABASE_PATH=./data/scrandle.db
