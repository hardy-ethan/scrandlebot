{
  "name": "scrandlebot",
  "version": "1.0.0",
  "description": "A Discord bot that scans, tracks and analyses Scrandle result messages.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsx --test test/*.test.ts"
  },
  "keywords": [
    "discord",
    "discord.js",
    "scrandle",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "better-sqlite3": "^11.3.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
